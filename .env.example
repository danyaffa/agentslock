# ═══════════════════════════════════════════════════════════════════════════════
# AgentsLock — Environment Variables
# Copy this file to .env and fill in your values.
# In Vercel, add each of these under Settings → Environment Variables.
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Firebase (client-side) ──────────────────────────────────────────────────
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# ─── PayPal (client-side) ───────────────────────────────────────────────────
VITE_PAYPAL_CLIENT_ID=
VITE_PAYPAL_PLAN_ID=

# ─── HIBP — HaveIBeenPwned API ──────────────────────────────────────────────
# Optional — $3.50/mo from https://haveibeenpwned.com/API/Key
VITE_HIBP_API_KEY=

# ─── Admin Access ─────────────────────────────────────────────────────────
# Admin email bypasses PayPal subscription — always gets full dashboard access
VITE_ADMIN_EMAIL=
# Admin password for accessing the Admin Dashboard (management panel)
VITE_ADMIN_ACCESS_PASSWORD=

# ─── Promo Code ──────────────────────────────────────────────────────────
# Set a promo code to allow guests to register with free access (no PayPal required)
VITE_PROMO_CODE=

# ─── App URL ────────────────────────────────────────────────────────────────
VITE_APP_URL=https://agentslock.com
